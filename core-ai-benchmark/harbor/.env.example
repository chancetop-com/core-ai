# Harbor benchmark configuration for core-ai-cli
# Copy to .env and edit:  cp .env.example .env

# --- Required ---

# LiteLLM API
LITELLM_API_KEY=sk-xxx
LITELLM_API_BASE=https://litellm.connexup-dev.net/v1

# Path to pre-extracted Linux JRE directory (offline Java)
# Run: make jre25-linux    # downloads and extracts automatically
CORE_AI_JRE_PATH=/tmp/jre25-linux

# --- Optional (auto-detected if not set) ---

# Path to Gradle installDist output (auto-detected from build/core-ai-cli/install/core-ai-cli)
# CORE_AI_INSTALL_DIR=/path/to/core-ai/build/core-ai-cli/install/core-ai-cli

# LLM model (provider/model format)
CORE_AI_MODEL=litellm/deepseek/deepseek-v4-flash
